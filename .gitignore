*.py[cod]
*$py.class

# Build and packaging artifacts
build/
dist/
site/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Test and coverage output
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# Streamlit local config and secrets
.streamlit/secrets.toml

# Editor and OS files
.vscode/
.idea/
*.swp
*.swo
Thumbs.db
.DS_Store

# Logs
*.log
