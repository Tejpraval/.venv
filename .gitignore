# Current repo was initialized inside the virtual environment.
# Ignore the environment internals so only app files remain visible.
Lib/
Scripts/
Include/
etc/
share/
pyvenv.cfg

# Virtual environments
.venv/
venv/
env/
ENV/

# Python cache and compiled files
